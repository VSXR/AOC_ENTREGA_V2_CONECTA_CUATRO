  8+  86E8              ; PRINTAT - Print a string in a position and attributes as per registers:
  9+  86E8              ;		IN	A	: Bit 7=1 For Flash / Bit 6=1 For Brigh / Bit 5,4,3 for Paper / Bit 2,1,0 for Ink
 10+  86E8              ;		IN	B	: Row 0..23
 11+  86E8              ;		IN	C	: Column 0..31
 12+  86E8              ;		IN	IX	: Address of text (Text must end in a 0)
 13+  86E8              ; ----------------------------------------------------------------------------------------
 14+  86E8 CD F7 86     PRINTAT:	CALL PREP_PRT				; Update Attribute var &Screen & Attributes pointers
 15+  86EB              ; ----------------------------------------------------------------------------------------
 16+  86EB              ;		VVV Do not move PRINTSTR below as PRINTAT continues into PRINTSTR routine
 17+  86EB              ; ----------------------------------------------------------------------------------------
 18+  86EB              ; PRINTSTR - Prints String - IX Points to the String start
 19+  86EB              ; ----------------------------------------------------------------------------------------
 20+  86EB DD 7E 00     PRINTSTR:   LD A,(IX)					; A Contains first char to print
 21+  86EE B7           			OR A						; check for end of string (0)
 22+  86EF C8           			RET Z						; Finish printing if 0
 23+  86F0 CD 25 87     			CALL PRINTCHNUM
 24+  86F3 DD 23        			INC IX						; Move to next char in string
 25+  86F5 18 F4        			JR PRINTSTR					; Start over printing sequence
