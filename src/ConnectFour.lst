  8+  800A              ; 1. CONSTANTES DE COLOR (ATRIBUTOS ZX SPECTRUM)
  9+  800A              ; ============================================================================================
 10+  800A              ; Formato Atributo (8 bits): INK + (PAPER*8) + (BRIGHT*64) + (FLASH*128)
 11+  800A              ; Donde:
 12+  800A              ; B = Bright (1=Brillante), F = Flash (1=Parpadeo)
 13+  800A              ; P = Paper (Color de fondo, 0-7)
 14+  800A              ; I = Ink (Color de tinta, 0-7)
 15+  800A              ;
 16+  800A              ; Valores base INK/PAPER: 0=Negro, 1=Azul, 2=Rojo, 3=Magenta, 4=Verde, 5=Cian, 6=Amarillo, 7=Blanco
 17+  800A              ; Valores base BRIGHT/FLASH: 0=Apagado, 1=Encendido
 18+  800A
 19+  800A              ; Valores base (0=Negro, 1=Azul, 2=Rojo, 3=Magenta, 4=Verde, 5=Cian, 6=Amarillo, 7=Blanco)
 20+  800A              COLOR_INK_NEGRO:         EQU 0
 21+  800A              COLOR_INK_AZUL:          EQU 1
 22+  800A              COLOR_INK_ROJO:          EQU 2
 23+  800A              COLOR_INK_MAGENTA:       EQU 3
 24+  800A              COLOR_INK_VERDE:         EQU 4
 25+  800A              COLOR_INK_CIAN:          EQU 5
 26+  800A              COLOR_INK_AMARILLO:      EQU 6
 27+  800A              COLOR_INK_BLANCO:        EQU 7
 28+  800A
 29+  800A              ; --- Atributos Compuestos Usados en el Juego ---
 30+  800A              ; Título (StartScreen)
 31+  800A              COLOR_AMARILLO_NEGRO:    EQU COLOR_INK_AMARILLO + (0*8) + (1*64)    ; Tinta: Amarillo Brillante, Fondo: Negro
 32+  800A
 33+  800A              ; Título (EndScreen) y Prompt (common.asm)
 34+  800A              COLOR_ROJO_BLANCO_FLASH: EQU COLOR_INK_ROJO + (7*8) + (1*64) + 128  ; Tinta: Rojo Brillante, Fondo: Blanco, Parpadeo
 35+  800A              COLOR_NEGRO_BLANCO:      EQU COLOR_INK_NEGRO + (7*8)                ; Tinta: Negro, Fondo: Blanco
 36+  800A
 37+  800A              ; Fondo del Tablero (tablero.asm)
 38+  800A              COLOR_PAPER_AZUL:        EQU (1*8)                                  ; Tinta: (Cualquiera), Fondo: Azul
 39+  800A              COLOR_PAPER_AZUL_BRT:    EQU (1*8) + (1*64)                         ; Tinta: (Cualquiera), Fondo: Azul Brillante
