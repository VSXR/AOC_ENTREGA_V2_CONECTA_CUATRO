  1+  8136              ; ============================================================================================
  2+  8136              ; ARCHIVO: input.asm
  3+  8136              ; USO: Lógica principal del juego (Conecta 3 - Convocatoria Extraordinaria).
  4+  8136              ;      Gestiona la inicialización, el movimiento vertical de la ficha del jugador,
  5+  8136              ;      la animación de deslizamiento horizontal y la lógica de turnos, victorias y empates.
  6+  8136              ;
  7+  8136              ;      Mecánica: El jugador selecciona una FILA (movimiento vertical).
  8+  8136              ;                Al confirmar, la ficha desliza de izquierda a derecha hasta chocar.
  9+  8136              ; ============================================================================================
 10+  8136
 11+  8136              ; ============================================================================================
 12+  8136              ; 1. INICIALIZACIÓN DE PARTIDA
 13+  8136              ; ============================================================================================
 14+  8136              ; --------------------------------------------------------------------------------------------
 15+  8136              ; INPUT_Inicializar_Teclado
 16+  8136              ; Prepara las variables de estado para una nueva partida.
 17+  8136              ; Se llama desde GAME_SCREEN antes del bucle principal de teclado.
 18+  8136              ;
 19+  8136              ; Entrada:  -
 20+  8136              ; Salida:   Variables de estado limpias, preview de P1 dibujada en fila 0
 21+  8136              ; Modifica: AF, BC, DE, HL (preservados con PUSH/POP)
 22+  8136              ; --------------------------------------------------------------------------------------------
 23+  8136              INPUT_Inicializar_Teclado:
 24+  8136 F5               PUSH AF
 24+  8137 C5             PUSH BC
 24+  8138 D5             PUSH DE
 24+  8139 E5             PUSH HL
 25+  813A
 26+  813A AF               XOR A
 27+  813B 32 06 81         LD (TOTAL_FICHAS_PUESTAS), A    ; Reiniciar contador de fichas
 28+  813E 32 04 81         LD (CURRENT_ROW), A             ; Ficha flotante empieza en fila 0
 29+  8141 32 0B 81         LD (GAME_OVER_REASON), A        ; 0 = en curso
 30+  8144
 31+  8144 3E 01            LD A, PLAYER_1
 32+  8146 32 03 81         LD (GUARDAR_JUGADOR_ACTUAL), A
 33+  8149
 34+  8149 CD 51 81         CALL DIBUJAR_FICHA_JUGADOR      ; Dibujar preview de P1
 35+  814C
 36+  814C E1               POP HL
 36+  814D D1             POP DE
 36+  814E C1             POP BC
 36+  814F F1             POP AF
 37+  8150 C9               RET
 38+  8151
