163+  81BF                  ; 1. BUSCAR COLUMNA VACÍA (EMPEZANDO POR LA DERECHA)
164+  81BF                  ; ======================================================
165+  81BF                  ; La fila buscada es CURRENT_ROW (fija). Iteramos columnas 6 -> 0.
166+  81BF                  ; Dirección de celda: BOARD_ARRAY + (CURRENT_ROW * 7) + columna
167+  81BF
168+  81BF 06 06            LD B, BOARD_COLS - 1  ; B = 6 (columna más a la derecha = "fondo" horizontal)
169+  81C1
