 27+  855C              ; --------------------------------------------------------------------------------------------
 28+  855C              ; KEYBOARD_WAIT_RELEASE
 29+  855C              ; Espera hasta que todas las teclas de una fila sean soltadas (debounce).
 30+  855C              ;
 31+  855C              ; Entrada:  BC = puerto de la fila de teclado a monitorizar
 32+  855C              ; Salida:   -
 33+  855C              ; Modifica: AF
 34+  855C              ; --------------------------------------------------------------------------------------------
 35+  855C              KEYBOARD_WAIT_RELEASE:
 36+  855C ED 78            IN A, (C)
 37+  855E E6 1F            AND $1F                         ; Solo los 5 bits de teclas
 38+  8560 FE 1F            CP $1F                          ; $1F = todas sueltas (lógica negativa)
 39+  8562 20 F8            JR NZ, KEYBOARD_WAIT_RELEASE
 40+  8564 C9               RET
 41+  8565
 42+  8565              ; ============================================================================================
 43+  8565              ; 2. LECTURA BLOQUEANTE (PARA MENÚS)
 44+  8565              ; ============================================================================================
 45+  8565              ; --------------------------------------------------------------------------------------------
 46+  8565              ; KEYBOARD_LEER_SN
 47+  8565              ; Detiene la ejecución hasta que el usuario pulsa 'S' o 'N'.
 48+  8565              ;
 49+  8565              ; Entrada:  -
 50+  8565              ; Salida:   A = 'S' o 'N'
 51+  8565              ; Modifica: AF, BC (BC preservado)
 52+  8565              ; --------------------------------------------------------------------------------------------
 53+  8565              KEYBOARD_LEER_SN:
 54+  8565 C5               PUSH BC
 55+  8566
 56+  8566              .CHECK_S:
 57+  8566 01 FE FD         LD BC, $FDFE        ; Fila A,S,D,F,G - Bit 1 = 'S'
 58+  8569 ED 78            IN A, (C)
 59+  856B CB 4F            BIT 1, A
 60+  856D 28 10            JR Z, .S_PRESSED
 61+  856F
 62+  856F              .CHECK_N:
 63+  856F 01 FE 7F         LD BC, $7FFE        ; Fila Space,Sym,M,N,B - Bit 3 = 'N'
 64+  8572 ED 78            IN A, (C)
 65+  8574 CB 5F            BIT 3, A
 66+  8576 20 EE            JR NZ, .CHECK_S
 67+  8578
 68+  8578              .N_PRESSED:
 69+  8578 CD 5C 85         CALL KEYBOARD_WAIT_RELEASE
 70+  857B 3E 4E            LD A, 'N'
 71+  857D C1               POP BC
 72+  857E C9               RET
 73+  857F
 74+  857F              .S_PRESSED:
 75+  857F CD 5C 85         CALL KEYBOARD_WAIT_RELEASE
 76+  8582 3E 53            LD A, 'S'
 77+  8584 C1               POP BC
 78+  8585 C9               RET
 79+  8586
 80+  8586              ; ============================================================================================
 81+  8586              ; 3. LECTURA NO BLOQUEANTE (POLLING PARA EL JUEGO)
 82+  8586              ; ============================================================================================
 83+  8586              ; --------------------------------------------------------------------------------------------
 84+  8586              ; KEYBOARD_POLL_PLAYER_MOVE
 85+  8586              ; Comprueba las teclas de movimiento vertical del jugador activo.
 86+  8586              ;
 87+  8586              ; Entrada:  (GUARDAR_JUGADOR_ACTUAL) - jugador activo (1, 2 o 3)
 88+  8586              ; Salida:   A = KEY_UP  si tecla arriba pulsada
 89+  8586              ;           A = KEY_DOWN si tecla abajo pulsada
 90+  8586              ;           A = 0       si ninguna tecla pulsada
 91+  8586              ; Modifica: AF, BC
 92+  8586              ; --------------------------------------------------------------------------------------------
 93+  8586              KEYBOARD_POLL_PLAYER_MOVE:
 94+  8586 3A 03 81         LD A, (GUARDAR_JUGADOR_ACTUAL)
 95+  8589 FE 02            CP PLAYER_2
 96+  858B 28 18            JR Z, .CHECK_P2_KEYS
 97+  858D FE 03            CP PLAYER_3
 98+  858F 28 28            JR Z, .CHECK_P3_KEYS
 99+  8591
100+  8591              .CHECK_P1_KEYS:
101+  8591                  ; P1: Q=Arriba ($FBFE/D0),  A=Abajo ($FDFE/D0)
102+  8591 01 FE FB         LD BC, $FBFE
103+  8594 ED 78            IN A, (C)
104+  8596 CB 47            BIT 0, A            ; Q = bit D0
105+  8598 28 33            JR Z, .RET_UP
106+  859A
107+  859A 01 FE FD         LD BC, $FDFE
108+  859D ED 78            IN A, (C)
109+  859F CB 47            BIT 0, A            ; A = bit D0
110+  85A1 28 2D            JR Z, .RET_DOWN
111+  85A3 18 26            JR .RET_NONE
112+  85A5
113+  85A5              .CHECK_P2_KEYS:
114+  85A5                  ; P2: E=Arriba ($FBFE/D2),  D=Abajo ($FDFE/D2)
115+  85A5 01 FE FB         LD BC, $FBFE
116+  85A8 ED 78            IN A, (C)
117+  85AA CB 57            BIT 2, A            ; E = bit D2
118+  85AC 28 1F            JR Z, .RET_UP
119+  85AE
120+  85AE 01 FE FD         LD BC, $FDFE
121+  85B1 ED 78            IN A, (C)
122+  85B3 CB 57            BIT 2, A            ; D = bit D2
123+  85B5 28 19            JR Z, .RET_DOWN
124+  85B7 18 12            JR .RET_NONE
125+  85B9
126+  85B9              .CHECK_P3_KEYS:
127+  85B9                  ; P3: T=Arriba ($FBFE/D4),  G=Abajo ($FDFE/D4)
128+  85B9 01 FE FB         LD BC, $FBFE
129+  85BC ED 78            IN A, (C)
130+  85BE CB 67            BIT 4, A            ; T = bit D4
131+  85C0 28 0B            JR Z, .RET_UP
132+  85C2
133+  85C2 01 FE FD         LD BC, $FDFE
134+  85C5 ED 78            IN A, (C)
135+  85C7 CB 67            BIT 4, A            ; G = bit D4
136+  85C9 28 05            JR Z, .RET_DOWN
137+  85CB
138+  85CB              .RET_NONE:
139+  85CB AF               XOR A
140+  85CC C9               RET
141+  85CD              .RET_UP:
142+  85CD 3E 55            LD A, KEY_UP
143+  85CF C9               RET
144+  85D0              .RET_DOWN:
145+  85D0 3E 44            LD A, KEY_DOWN
146+  85D2 C9               RET
147+  85D3
148+  85D3              ; --------------------------------------------------------------------------------------------
149+  85D3              ; KEYBOARD_POLL_CONFIRM
150+  85D3              ; Comprueba si el jugador activo ha pulsado su tecla CONFIRMAR.
151+  85D3              ;
152+  85D3              ; Entrada:  (GUARDAR_JUGADOR_ACTUAL) - jugador activo (1, 2 o 3)
153+  85D3              ; Salida:   A = KEY_CONFIRM (13) si pulsada, A = 0 si no
154+  85D3              ; Modifica: AF, BC
155+  85D3              ; --------------------------------------------------------------------------------------------
156+  85D3              KEYBOARD_POLL_CONFIRM:
157+  85D3 3A 03 81         LD A, (GUARDAR_JUGADOR_ACTUAL)
158+  85D6 FE 02            CP PLAYER_2
159+  85D8 28 0F            JR Z, .CONFIRM_P2
160+  85DA FE 03            CP PLAYER_3
161+  85DC 28 16            JR Z, .CONFIRM_P3
162+  85DE
163+  85DE              .CONFIRM_P1:
164+  85DE                  ; Z = $FEFE / bit D1
165+  85DE 01 FE FE         LD BC, $FEFE
166+  85E1 ED 78            IN A, (C)
167+  85E3 CB 4F            BIT 1, A
168+  85E5 20 19            JR NZ, .NO_CONFIRM
169+  85E7 18 14            JR .YES_CONFIRM
170+  85E9
171+  85E9              .CONFIRM_P2:
172+  85E9                  ; C = $FEFE / bit D3
173+  85E9 01 FE FE         LD BC, $FEFE
174+  85EC ED 78            IN A, (C)
175+  85EE CB 5F            BIT 3, A
176+  85F0 20 0E            JR NZ, .NO_CONFIRM
177+  85F2 18 09            JR .YES_CONFIRM
178+  85F4
179+  85F4              .CONFIRM_P3:
180+  85F4                  ; B = $7FFE / bit D4
181+  85F4 01 FE 7F         LD BC, $7FFE
182+  85F7 ED 78            IN A, (C)
183+  85F9 CB 67            BIT 4, A
184+  85FB 20 03            JR NZ, .NO_CONFIRM
185+  85FD
186+  85FD              .YES_CONFIRM:
187+  85FD 3E 0D            LD A, KEY_CONFIRM
188+  85FF C9               RET
189+  8600              .NO_CONFIRM:
190+  8600 AF               XOR A
191+  8601 C9               RET
