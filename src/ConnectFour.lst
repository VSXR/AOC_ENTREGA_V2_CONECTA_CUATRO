  1   0000              ; ============================================================================================
  2   0000              ; ARCHIVO: ConnectFour.asm
  3   0000              ; USO: Archivo principal y punto de entrada (entry point) del juego "Conecta 3".
  4   0000              ;      Define la configuración del ensamblador Z80, inicializa la CPU,
  5   0000              ;      la pila (stack) y transfiere el control a la pantalla de inicio.
  6   0000              ; ============================================================================================
  7   0000
  8   0000                  DEVICE ZXSPECTRUM48
  9   0000              	SLDOPT COMMENT WPMEM, LOGPOINT, ASSETION
 10   0000                  ORG $8000
 11   8000
 12   8000              ; ============================================================================================
 13   8000              ; PUNTO DE ENTRADA E INICIALIZACIÓN
 14   8000              ; ============================================================================================
 15   8000              BEGIN:
 16   8000 F3               DI
 17   8001 31 FF FF         LD SP, $FFFF        ; Inicializamos la pila al final de la memoria para no chocar con la direccion ORG $8000 (por si acaso)
 18   8004
 19   8004 CD 59 87         CALL CLEARSCR
 20   8007 C3 E6 8A         JP START_SCREEN
 21   800A
 22   800A              ; ============================================================================================
 23   800A              ; INCLUDES DEL PROYECTO (ARCHIVOS .ASM)
 24   800A              ; ============================================================================================
