 46+  849D                  ; La ficha mide 2 celdas + 2 celdas de barra azul = 4 celdas
 47+  849D 7D               LD A, L
 48+  849E C6 04            ADD A, 4                     ; Avanza 4 columnas de caracteres
 49+  84A0 6F               LD L, A
 50+  84A1
 51+  84A1 1D               DEC E                        ; Decrementar contador de columnas (E)
 52+  84A2 20 F0            JR NZ, TABLERO_Col_Loop      ; Repetir 7 veces
 53+  84A4
 54+  84A4 E1               POP HL                       ; Recuperar H (posición Y de la fila)
 55+  84A5
 56+  84A5                  ; Avanzar a la siguiente fila de huecos
 57+  84A5                  ; La ficha mide 2 celdas + 1 celda de barra azul = 3 celdas
 58+  84A5 7C               LD A, H
 59+  84A6 C6 03            ADD A, 3                     ; Avanza 3 filas de caracteres
 60+  84A8 67               LD H, A
 61+  84A9
 62+  84A9 15               DEC D                        ; Decrementar contador de filas (D)
 63+  84AA 20 E3            JR NZ, TABLERO_Row_Loop      ; Repetir 6 veces
 64+  84AC
 65+  84AC DD E1            POP IX
 65+  84AE E1             POP HL
 65+  84AF D1             POP DE
 65+  84B0 C1             POP BC
 65+  84B1 F1             POP AF
