102+  8AD0                  ; Si no fue 'S', fue 'N'
103+  8AD0 AF               XOR A                       ; A = 0 (No)
104+  8AD1 C9               RET
105+  8AD2              .RETURN_YES:
106+  8AD2 3E 01            LD A, 1                     ; A = 1 (Sí)
107+  8AD4 C9               RET
108+  8AD5
109+  8AD5              ; --------------------------------------------------------------------------------------------
110+  8AD5              ; COMMON_MESSAGE_BYE_SCREEN
111+  8AD5              ; Muestra la pantalla de despedida y detiene la ejecución del programa.
