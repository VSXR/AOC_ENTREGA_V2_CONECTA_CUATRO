 10+  826F              ; RUTINA PRINCIPAL: CHECK_WIN
 11+  826F              ; ============================================================================================
 12+  826F              ; USO:
 13+  826F              ;   Comprueba si la última jugada (almacenada en LAST_ROW, LAST_COL)
 14+  826F              ;   ha resultado en una victoria para el jugador actual (GUARDAR_JUGADOR_ACTUAL).
 15+  826F              ;
 16+  826F              ; ENTRADA:
 17+  826F              ;   (Implícita) (LAST_ROW), (LAST_COL) -> Coordenadas de la última ficha.
 18+  826F              ;   (Implícita) (GUARDAR_JUGADOR_ACTUAL) -> Jugador que acaba de mover.
 19+  826F              ;
 20+  826F              ; SALIDA:
 21+  826F              ;   Carry Flag (C) = 1 (SCF) SI HAY VICTORIA
 22+  826F              ;   Carry Flag (C) = 0 (OR A) SI NO HAY VICTORIA
 23+  826F              ; --------------------------------------------------------------------------------------------
 24+  826F              CHECK_WIN:
 25+  826F C5               PUSH BC
 25+  8270 D5             PUSH DE
 25+  8271 E5             PUSH HL  ; Preservar registros
 26+  8272
 27+  8272                  ; 1. Comprobar HORIZONTAL
 28+  8272                  ;    (Fila fija, Columna se mueve +/- 1)
 29+  8272 16 00            LD D, 0                     ; Delta Fila = 0
 30+  8274 1E 01            LD E, 1                     ; Delta Columna = 1
 31+  8276 CD A0 82         CALL CHECK_LINE
 32+  8279 38 20            JR C, .WIN_FOUND            ; Si Carry=1, saltar al final
 33+  827B
 34+  827B                  ; 2. Comprobar VERTICAL
 35+  827B                  ;    (Fila se mueve +/- 1, Columna fija)
 36+  827B 16 01            LD D, 1                     ; Delta Fila = 1
 37+  827D 1E 00            LD E, 0                     ; Delta Columna = 0
 38+  827F CD A0 82         CALL CHECK_LINE
 39+  8282 38 17            JR C, .WIN_FOUND
 40+  8284
 41+  8284                  ; 3. Comprobar DIAGONAL \
 42+  8284                  ;    (Fila se mueve +/- 1, Columna se mueve +/- 1)
 43+  8284 16 01            LD D, 1                     ; Delta Fila = 1
 44+  8286 1E 01            LD E, 1                     ; Delta Columna = 1
 45+  8288 CD A0 82         CALL CHECK_LINE
 46+  828B 38 0E            JR C, .WIN_FOUND
 47+  828D
 48+  828D                  ; 4. Comprobar DIAGONAL /
 49+  828D                  ;    (Fila se mueve +/- 1, Columna se mueve -/+ 1)
 50+  828D 16 01            LD D, 1                     ; Delta Fila = 1
 51+  828F 1E FF            LD E, -1                    ; Delta Columna = -1 (255 en complemento a 2)
 52+  8291 CD A0 82         CALL CHECK_LINE
