 49+  852F              ; FUNCIÓN: UTIL_VISUAL_ERROR_FULL_ROW
 50+  852F              ; Realiza un efecto visual de error (borde rojo parpadeante)
 51+  852F              ; parpadeando 2 veces lentamente para indicar que la fila elegida está llena.
 52+  852F              ; ==========================================================================
 53+  852F              UTIL_VISUAL_ERROR_FULL_ROW:
 54+  852F F5               PUSH AF
 54+  8530 C5             PUSH BC
 54+  8531 D5             PUSH DE
 55+  8532 16 02            LD D, 2     ;Contador para parpadear 2 veces
 56+  8534
 57+  8534              .BLINK_LOOP:
 58+  8534                  ; --- 1. Poner Borde ROJO ---
 59+  8534 3E 02            LD A, 2                     ; Color Rojo
 60+  8536 D3 FE            OUT ($FE), A                ; Cambiar borde
 61+  8538
 62+  8538                  ; --- 2. Pausa Larga (Encendido) ---
 63+  8538 01 A8 61         LD BC, 25000                ; Retardo para pausa larga del parpadeo
 64+  853B CD 4F 85         CALL UTIL_Pausar
 65+  853E
 66+  853E                  ; --- 3. Restaurar Borde (BLANCO) ---
 67+  853E 3E 07            LD A, 7                     ; Color Blanco
 68+  8540 D3 FE            OUT ($FE), A                ; Restaurar borde
 69+  8542
 70+  8542                  ; --- 4. Pausa Larga (Apagado) ---
 71+  8542                  ; OJO: Aqui es importante pausar también para que se note el "apagado" antes
 72+  8542                  ; del siguiente parpadeo!
 73+  8542 01 A8 61         LD BC, 25000                ; Mismo retardo
 74+  8545 CD 4F 85         CALL UTIL_Pausar
 75+  8548
 76+  8548                  ; --- 5. Control del Bucle ---
 77+  8548 15               DEC D                       ; Restamos 1 al contador (D)
 78+  8549 20 E9            JR NZ, .BLINK_LOOP          ; Si D no es 0, saltamos al inicio para parpadear otra vez
 79+  854B
 80+  854B D1               POP DE
 80+  854C C1             POP BC
 80+  854D F1             POP AF
