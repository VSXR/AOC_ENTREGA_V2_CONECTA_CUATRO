137+  82C2 3A 07 81         LD A, (LAST_ROW)
138+  82C5 67               LD H, A                     ; H = Fila actual
139+  82C6 3A 08 81         LD A, (LAST_COL)
140+  82C9 6F               LD L, A                     ; L = Columna actual
141+  82CA
142+  82CA              .LOOP_COUNT:
143+  82CA                  ; --- 1. Mover a la siguiente celda ---
144+  82CA 7C               LD A, H
145+  82CB 82               ADD A, D                    ; H = H + Delta Fila
146+  82CC 67               LD H, A
147+  82CD 7D               LD A, L
148+  82CE 83               ADD A, E                    ; L = L + Delta Columna
149+  82CF 6F               LD L, A
150+  82D0
151+  82D0                  ; --- 2. VALIDAR LÍMITES DEL TABLERO ---
152+  82D0                  ; Verificar Fila (H debe estar entre 0 y 5)
153+  82D0 7C               LD A, H
154+  82D1 FE 06            CP 6                        ; Compara H con 6
155+  82D3 30 24            JR NC, .END_COUNT           ; Si H >= 6 (o < 0, que es >127), está fuera de rango.
156+  82D5
157+  82D5                  ; Verificar Columna (L debe estar entre 0 y 6)
158+  82D5 7D               LD A, L
159+  82D6 FE 07            CP 7                        ; Compara L con 7
160+  82D8 30 1F            JR NC, .END_COUNT           ; Si L >= 7 (o < 0), está fuera de rango.
161+  82DA
162+  82DA                  ; --- 3. LEER VALOR EN TABLERO (BOARD_ARRAY) ---
163+  82DA                  ; La celda (H, L) es válida, ahora calculamos su índice en el array 1D
164+  82DA                  ; Índice = (H * 7) + L
165+  82DA E5               PUSH HL
165+  82DB D5             PUSH DE            ; Guardar H,L (coords) y D,E (deltas)
166+  82DC
167+  82DC 7C               LD A, H                     ; A = H (Fila)
168+  82DD 87               ADD A, A                    ; A = H * 2
169+  82DE 87               ADD A, A                    ; A = H * 4
170+  82DF 57               LD D, A                     ; D = H * 4
171+  82E0
172+  82E0 7C               LD A, H                     ; A = H
173+  82E1 87               ADD A, A                    ; A = H * 2
174+  82E2 84               ADD A, H                    ; A = H * 3
175+  82E3
176+  82E3 82               ADD A, D                    ; A = (H * 3) + (H * 4) = H * 7
177+  82E4 85               ADD A, L                    ; A = (H * 7) + L (Índice final)
178+  82E5
179+  82E5 5F               LD E, A                     ; E = Índice
180+  82E6 16 00            LD D, 0                     ; DE = Índice (16 bits)
181+  82E8 21 0C 81         LD HL, BOARD_ARRAY
182+  82EB 19               ADD HL, DE                  ; HL = Dirección de la celda (BOARD_ARRAY + Índice)
183+  82EC 7E               LD A, (HL)                  ; A = Valor de la celda (0=Vacío, 1=P1, 2=P2)
184+  82ED
185+  82ED D1               POP DE
185+  82EE E1             POP HL              ; Recuperar H,L y D,E
186+  82EF
187+  82EF                  ; --- 4. COMPARAR CON JUGADOR ACTUAL ---
188+  82EF 4F               LD C, A                     ; Guardamos el valor de la celda en C
189+  82F0 3A 03 81         LD A, (GUARDAR_JUGADOR_ACTUAL)
190+  82F3 B9               CP C                        ; ¿Es la celda (C) igual a nuestro jugador (A)?
191+  82F4 20 03            JR NZ, .END_COUNT           ; Si no coincide (es 0 o del otro jugador), parar de contar
192+  82F6
193+  82F6                  ; --- 5. COINCIDENCIA ---
194+  82F6 04               INC B                       ; Coincide! --> Incrementamos contador de aciertos
195+  82F7 18 D1            JR .LOOP_COUNT              ; Volver al bucle para comprobar la siguiente celda
196+  82F9
197+  82F9              .END_COUNT:
198+  82F9 78               LD A, B                     ; Cargar el total de aciertos (B) en A para el retorno
199+  82FA E1               POP HL
199+  82FB D1             POP DE
199+  82FC C1             POP BC
200+  82FD C9               RET
