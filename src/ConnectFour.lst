 68+  82A0              ; RUTINA AUXILIAR: CHECK_LINE
 69+  82A0              ; ============================================================================================
 70+  82A0              ; USO:
 71+  82A0              ;   Comprueba una línea completa (en ambas direcciones) usando un vector (D,E).
 72+  82A0              ;   Suma las fichas encontradas en la dirección (D,E) y la opuesta (-D,-E).
 73+  82A0              ;
 74+  82A0              ; ENTRADA:
 75+  82A0              ;   D = Delta Fila
 76+  82A0              ;   E = Delta Columna
 77+  82A0              ;
 78+  82A0              ; SALIDA:
 79+  82A0              ;   Carry Flag = 1 si la suma total (dir_1 + dir_2 + ficha_central) >= WIN_LENGTH (3)
 80+  82A0              ;   Carry Flag = 0 si no
 81+  82A0              ; --------------------------------------------------------------------------------------------
 82+  82A0              CHECK_LINE:
 83+  82A0 D5               PUSH DE                     ; Guardamos los deltas originales (D, E)
 84+  82A1
 85+  82A1                  ; 1. Contar en la primera dirección (D, E)
