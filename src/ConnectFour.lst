 84+  854F              ; FUNCIÓN: UTIL_Pausar
 85+  854F              ; Realiza una pausa (delay) simple. Es un "bucle loco" (busy-loop).
 86+  854F              ;
 87+  854F              ; ENTRADAS:
 88+  854F              ;   BC = Duración de la pausa (16 bits). Un valor más alto tarda más.
 89+  854F              ;        (Ej: 60000 para una pausa larga).
 90+  854F              ; ==========================================================================
 91+  854F              UTIL_Pausar:
 92+  854F C5               PUSH BC                     ; Preservar BC (aunque sea el contador)
 93+  8550              .Pause_Loop:
 94+  8550 0B               DEC BC                      ; Decrementa el contador de 16 bits
 95+  8551 78               LD A, B                     ; Cargar byte alto
 96+  8552 B1               OR C                        ; Comprobar si el byte bajo también es 0
 97+  8553 20 FB            JR NZ, .Pause_Loop          ; Si BC no es 0, seguir en el bucle
 98+  8555 C1               POP BC                      ; Restaurar BC
 99+  8556 C9               RET
