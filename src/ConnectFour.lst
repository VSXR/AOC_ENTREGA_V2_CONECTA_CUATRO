243+  862D              ; ============================================================================================
244+  862D              ; 4. BUCLE PRINCIPAL DE ENTRADA (GAME INPUT LOOP)
245+  862D              ; ============================================================================================
246+  862D              ; Bucle ocupado (busy-loop) sin HALT. El temporizador de 16 bits controla la velocidad
247+  862D              ; del movimiento vertical del preview para evitar desplazamiento demasiado rápido.
248+  862D              ;
249+  862D              ; Flujo: inicializar -> poll teclas -> gestionar movimiento/confirmación -> redibujar -> repetir
250+  862D
251+  862D              KEYBOARD_ActivarInput_Keys:
252+  862D CD 36 81         CALL INPUT_Inicializar_Teclado  ; Prepara estado inicial y dibuja preview de P1
253+  8630
254+  8630                  ; Sincronizar PREVIOUS_ROW con la fila inicial
255+  8630 3A 04 81         LD A, (CURRENT_ROW)
256+  8633 32 05 81         LD (PREVIOUS_ROW), A
257+  8636
258+  8636                  ; Inicializar temporizador de 16 bits a 0 (permite movimiento inmediato)
259+  8636 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
260+  8639 AF               XOR A
261+  863A 77               LD (HL), A
262+  863B 23               INC HL
263+  863C 77               LD (HL), A
264+  863D
265+  863D              .LOOP:
266+  863D                  ; --- 1. GESTIÓN DEL TEMPORIZADOR DE COOLDOWN (16 bits) ---
267+  863D 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
268+  8640 4E               LD C, (HL)
269+  8641 23               INC HL
270+  8642 46               LD B, (HL)
271+  8643
272+  8643 78               LD A, B
273+  8644 B1               OR C
274+  8645 28 07            JR Z, .SKIP_COOLDOWN_DEC
275+  8647
276+  8647 0B               DEC BC
277+  8648 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
278+  864B 71               LD (HL), C
279+  864C 23               INC HL
280+  864D 70               LD (HL), B
281+  864E
282+  864E              .SKIP_COOLDOWN_DEC:
283+  864E                  ; --- 2. SONDEO DE TECLAS DE MOVIMIENTO ---
284+  864E CD 86 85         CALL KEYBOARD_POLL_PLAYER_MOVE
285+  8651
286+  8651 FE 55            CP KEY_UP
287+  8653 28 16            JR Z, .HANDLE_UP_CONTINUOUS
288+  8655 FE 44            CP KEY_DOWN
289+  8657 28 31            JR Z, .HANDLE_DOWN_CONTINUOUS
290+  8659
291+  8659                  ; --- 3. SONDEO DE CONFIRMAR Y SALIR ---
292+  8659 CD D3 85         CALL KEYBOARD_POLL_CONFIRM
293+  865C FE 0D            CP KEY_CONFIRM
294+  865E CA CA 86         JP Z, .HANDLE_CONFIRM_PRESS
295+  8661
296+  8661 CD 1F 86         CALL KEYBOARD_POLL_F
297+  8664 FE 46            CP 'F'
298+  8666 CA DF 86         JP Z, .HANDLE_F_PRESS
299+  8669
300+  8669 18 D2            JR .LOOP
301+  866B
302+  866B              ; --------------------------------------------------------------------------------------------
303+  866B              ; MANEJADORES DE MOVIMIENTO VERTICAL (ARRIBA y ABAJO)
304+  866B              ; --------------------------------------------------------------------------------------------
305+  866B              .HANDLE_UP_CONTINUOUS:
306+  866B                  ; Recargar temporizador (BC destruido por KEYBOARD_POLL_PLAYER_MOVE)
307+  866B 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
308+  866E 4E               LD C, (HL)
309+  866F 23               INC HL
310+  8670 46               LD B, (HL)
311+  8671
312+  8671 78               LD A, B
313+  8672 B1               OR C
314+  8673 20 35            JR NZ, .CHECK_REDRAW        ; Timer activo -> no mover!!
315+  8675
316+  8675                  ; Timer = 0: mover si no estamos en la fila 0
317+  8675 3A 04 81         LD A, (CURRENT_ROW)
318+  8678 B7               OR A                        ; ¿Ya en fila 0?
319+  8679 28 2F            JR Z, .CHECK_REDRAW
320+  867B 3D               DEC A
321+  867C 32 04 81         LD (CURRENT_ROW), A
322+  867F
323+  867F 01 DC 05         LD BC, MOVE_DELAY_FRAMES
324+  8682 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
325+  8685 71               LD (HL), C
326+  8686 23               INC HL
327+  8687 70               LD (HL), B
328+  8688
329+  8688 18 20            JR .CHECK_REDRAW
330+  868A
331+  868A              .HANDLE_DOWN_CONTINUOUS:
332+  868A 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
333+  868D 4E               LD C, (HL)
334+  868E 23               INC HL
335+  868F 46               LD B, (HL)
336+  8690
337+  8690 78               LD A, B
338+  8691 B1               OR C
339+  8692 20 16            JR NZ, .CHECK_REDRAW
340+  8694
341+  8694                  ; Timer = 0: mover si no estamos en la fila 5 (BOARD_ROWS - 1)
342+  8694 3A 04 81         LD A, (CURRENT_ROW)
343+  8697 FE 05            CP BOARD_ROWS - 1           ; ¿Ya en fila 5?
344+  8699 28 0F            JR Z, .CHECK_REDRAW
345+  869B 3C               INC A
346+  869C 32 04 81         LD (CURRENT_ROW), A
347+  869F
348+  869F 01 DC 05         LD BC, MOVE_DELAY_FRAMES
349+  86A2 21 09 81         LD HL, MOVE_COOLDOWN_TIMER
350+  86A5 71               LD (HL), C
351+  86A6 23               INC HL
352+  86A7 70               LD (HL), B
353+  86A8
354+  86A8 18 00            JR .CHECK_REDRAW
355+  86AA
356+  86AA              ; --------------------------------------------------------------------------------------------
357+  86AA              ; RUTINA DE REDIBUJADO - Previene parpadeo comparando fila actual con la anterior
358+  86AA              ; --------------------------------------------------------------------------------------------
359+  86AA              .CHECK_REDRAW:
360+  86AA 3A 04 81         LD A, (CURRENT_ROW)         ; A = fila nueva
361+  86AD 47               LD B, A
362+  86AE 3A 05 81         LD A, (PREVIOUS_ROW)        ; A = fila antigua
363+  86B1 B8               CP B
364+  86B2 28 89            JR Z, .LOOP                 ; Sin cambio, no redibujar
365+  86B4
366+  86B4                  ; 1. Borrar preview en la posición ANTIGUA
367+  86B4 3A 05 81         LD A, (PREVIOUS_ROW)
368+  86B7 32 04 81         LD (CURRENT_ROW), A         ; Temporalmente apuntamos a la fila antigua
369+  86BA CD 76 81         CALL ERASE_PREVIEW
370+  86BD
371+  86BD                  ; 2. Dibujar preview en la posición NUEVA
372+  86BD 78               LD A, B
373+  86BE 32 04 81         LD (CURRENT_ROW), A
374+  86C1 CD 51 81         CALL DIBUJAR_FICHA_JUGADOR
375+  86C4
376+  86C4                  ; 3. Sincronizar PREVIOUS_ROW
377+  86C4 32 05 81         LD (PREVIOUS_ROW), A
378+  86C7 C3 3D 86         JP .LOOP
379+  86CA
380+  86CA              ; --------------------------------------------------------------------------------------------
