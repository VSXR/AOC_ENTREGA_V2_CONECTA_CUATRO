  7+  8475              ; FUNCIÓN PRINCIPAL: TABLERO_DibujarTableroCompleto
  8+  8475              ; Dibuja el tablero de juego completo: un gran fondo azul y 42 huecos negros
  9+  8475              ; (que son en realidad fichas negras) para crear la cuadrícula.
 10+  8475              ; ============================================================================================
 11+  8475              TABLERO_DibujarTableroCompleto:
 12+  8475 F5               PUSH AF
 12+  8476 C5             PUSH BC
 12+  8477 D5             PUSH DE
 12+  8478 E5             PUSH HL
 12+  8479 DD E5          PUSH IX
 13+  847B CD 59 87         CALL CLEARSCR
 14+  847E
 15+  847E                  ; === PASO 1: Pintar fondo azul completo (19x29) ===
 16+  847E 26 03            LD H, 3                             ; Fila inicial (Y)
 17+  8480 2E 03            LD L, 3                             ; Columna inicial (X)
 18+  8482 06 13            LD B, 19                            ; Alto (19 filas de caracteres)
 19+  8484 0E 1C            LD C, 28                            ; Ancho (28 columnas de caracteres)
 20+  8486 3E 08            LD A, COLOR_PAPER_AZUL              ; Color de atributo (Fondo Azul)
 21+  8488 CD B3 84         CALL TABLERO_RellenarRectAtributo   ; Llama a la subrutina que rellena
 22+  848B
 23+  848B                  ; === PASO 2: Pintar los 42 huecos negros (Grid 6x7) ===
 24+  848B                  ; Usamos un bucle anidado para dibujar 6 filas de 7 huecos cada una.
 25+  848B 26 04            LD H, 4                      ; H = Fila Y inicial del primer hueco (Fila Lógica 0)
 26+  848D 16 06            LD D, 6                      ; D = Contador de filas de huecos (6 filas)
 27+  848F
 28+  848F              TABLERO_Row_Loop:
 29+  848F E5               PUSH HL                      ; Guardar H (posición Y de la fila actual)
 30+  8490 2E 04            LD L, 4                      ; L = Columna X inicial (Columna Lógica 0)
 31+  8492 1E 07            LD E, 7                      ; E = Contador de columnas de huecos (7 columnas)
 32+  8494
 33+  8494              TABLERO_Col_Loop:
 34+  8494 D5               PUSH DE                      ; Guardar contadores D (filas) y E (columnas)
 35+  8495 E5               PUSH HL                      ; Guardar H,L (posición actual del hueco)
 36+  8496
 37+  8496                  ; Pintar un HUECO (una ficha negra sobre fondo azul)
 38+  8496                  ; Se usa la misma rutina que para pintar fichas de jugador.
 39+  8496 3E 08            LD A, COLOR_INK_NEGRO + COLOR_PAPER_AZUL
 40+  8498 CD 4E 83         CALL FICHAS_PintarFicha_AjustadaTablero
 41+  849B
 42+  849B E1               POP HL                       ; Recuperar H,L
 43+  849C D1               POP DE                       ; Recuperar D,E
 44+  849D
