  8+  8424              ; FUNCIÓN: POSXY_CalcPixelAddr_4000
  9+  8424              ;
 10+  8424              ; DESCRIPCIÓN:
 11+  8424              ;   Calcula la dirección de memoria de PÍXELES (rango $4000 - $57FF)
 12+  8424              ;   correspondiente a una coordenada (H=Y, L=X).
 13+  8424              ;
 14+  8424              ;   La pantalla del Spectrum está dividida en 3 tercios (cuadrantes) verticales:
 15+  8424              ;    - 1er Tercio (Y: 0-7)   -> Base $4000
 16+  8424              ;    - 2do Tercio (Y: 8-15)  -> Base $4800
 17+  8424              ;    - 3er Tercio (Y: 16-23) -> Base $5000
 18+  8424              ;
 19+  8424              ; ENTRADA: H = Coordenada Y (0-23), L = Coordenada X (0-31)
 20+  8424              ; SALIDA:  HL = Dirección en memoria de vídeo ($4xxx o $5xxx)
 21+  8424              ; ====================================================================================================
 22+  8424              POSXY_CalcPixelAddr_4000:
 23+  8424 F5               PUSH AF
 23+  8425 C5             PUSH BC
 23+  8426 D5             PUSH DE             ; Preservar registros
 24+  8427
 25+  8427 1E 40            LD E, $40                             ; Base por defecto = $4000 (1er tercio)
