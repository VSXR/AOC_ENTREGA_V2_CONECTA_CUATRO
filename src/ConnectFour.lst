 87+  82A4 47               LD B, A                     ; B = Número de fichas encontradas en la primera dirección
 88+  82A5
 89+  82A5                  ; 2. Invertir la dirección para comprobar el lado opuesto
 90+  82A5 D1               POP DE                      ; Recuperamos los deltas originales (D, E)
 91+  82A6 7A               LD A, D
 92+  82A7 ED 44            NEG                         ; A = -D (Invierte el delta de fila)
 93+  82A9 57               LD D, A
 94+  82AA 7B               LD A, E
 95+  82AB ED 44            NEG                         ; A = -E (Invierte el delta de columna)
 96+  82AD 5F               LD E, A
 97+  82AE
 98+  82AE                  ; 3. Contar en la dirección opuesta (-D, -E)
 99+  82AE C5               PUSH BC                     ; Guardamos la primera cuenta (B)
100+  82AF CD BD 82         CALL COUNT_CONSECUTIVE
101+  82B2 C1               POP BC                      ; Recuperamos la primera cuenta (B)
102+  82B3
103+  82B3                  ; 4. Sumar resultados
104+  82B3 80               ADD A, B                    ; A = (Cuenta Dir 1) + (Cuenta Dir 2)
105+  82B4 3C               INC A                       ; Sumar 1 (la ficha central que acabamos de poner)
106+  82B5
107+  82B5                  ; 5. Comprobar si hay WIN_LENGTH o más en raya
108+  82B5 FE 03            CP WIN_LENGTH               ; ¿Es el total (A) >= WIN_LENGTH (= 3)?
109+  82B7 30 02            JR NC, .LINE_WIN            ; Si A >= WIN_LENGTH (No Carry), es victoria
110+  82B9
111+  82B9 B7               OR A                        ; No hay victoria en esta línea, CF = 0
112+  82BA C9               RET
