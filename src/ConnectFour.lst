 19+  8557              ; COLOR_BORDE_PANTALLA
 20+  8557              ; Pone el borde de la pantalla en blanco (7).
 21+  8557              ; --------------------------------------------------------------------------------------------
 22+  8557              COLOR_BORDE_PANTALLA:
 23+  8557 3E 07            LD A, 7
 24+  8559 D3 FE            OUT (254), A
