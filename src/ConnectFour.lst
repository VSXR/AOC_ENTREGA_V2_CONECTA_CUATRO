193+  8602              ; --------------------------------------------------------------------------------------------
194+  8602              ; KEYBOARD_WAIT_RELEASE_CONFIRM
195+  8602              ; Espera a que el jugador activo suelte su tecla CONFIRMAR (debounce post-acción).
196+  8602              ;
197+  8602              ; Entrada:  (GUARDAR_JUGADOR_ACTUAL) - jugador activo (1, 2 o 3)
198+  8602              ; Salida:   -
199+  8602              ; Modifica: AF, BC
200+  8602              ; --------------------------------------------------------------------------------------------
201+  8602              KEYBOARD_WAIT_RELEASE_CONFIRM:
202+  8602 F5               PUSH AF
203+  8603 3A 03 81         LD A, (GUARDAR_JUGADOR_ACTUAL)
204+  8606 FE 02            CP PLAYER_2
205+  8608 28 09            JR Z, .WR_P2
206+  860A FE 03            CP PLAYER_3
207+  860C 28 0A            JR Z, .WR_P3
208+  860E
209+  860E              .WR_P1:
210+  860E 01 FE FE         LD BC, $FEFE        ; Puerto de Z (P1 confirm)
211+  8611 18 08            JR .DO_WAIT
212+  8613
213+  8613              .WR_P2:
214+  8613 01 FE FE         LD BC, $FEFE        ; Puerto de C (P2 confirm)
215+  8616 18 03            JR .DO_WAIT
216+  8618
217+  8618              .WR_P3:
218+  8618 01 FE 7F         LD BC, $7FFE        ; Puerto de B (P3 confirm)
219+  861B
220+  861B              .DO_WAIT:
221+  861B F1               POP AF
222+  861C C3 5C 85         JP KEYBOARD_WAIT_RELEASE    ; Preserva AF ya recuperado
223+  861F
224+  861F              ; --------------------------------------------------------------------------------------------
225+  861F              ; KEYBOARD_POLL_F
226+  861F              ; Comprueba si 'F' (salir del juego) está pulsada.
227+  861F              ;
228+  861F              ; Entrada:  -
229+  861F              ; Salida:   A = 'F' o 0
230+  861F              ; Modifica: AF, BC
231+  861F              ; --------------------------------------------------------------------------------------------
232+  861F              KEYBOARD_POLL_F:
233+  861F 01 FE FD         LD BC, $FDFE        ; Fila A,S,D,F,G - Bit 3 = 'F'
234+  8622 ED 78            IN A, (C)
235+  8624 CB 5F            BIT 3, A
236+  8626 20 03            JR NZ, .NO_F
237+  8628 3E 46            LD A, 'F'
238+  862A C9               RET
239+  862B              .NO_F:
240+  862B AF               XOR A
241+  862C C9               RET
