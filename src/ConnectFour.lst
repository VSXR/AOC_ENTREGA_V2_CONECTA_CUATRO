  7+  8A6C
  8+  8A6C              ; --------------------------------------------------------------------------------------------
  9+  8A6C              ; COMMON_INIT_SCREEN
 10+  8A6C              ; Limpia la pantalla completa, pone el borde negro y establece los atributos
 11+  8A6C              ; de color por defecto (llamando a la rutina de borde blanco).
 12+  8A6C              ; --------------------------------------------------------------------------------------------
 13+  8A6C              COMMON_INIT_SCREEN:
 14+  8A6C AF               XOR A                       ; A = 0
 15+  8A6D D3 FE            OUT ($FE), A                ; Establece el color del borde a 0 (Negro)
 16+  8A6F CD 59 87         CALL CLEARSCR               ; Llama a la ROM para borrar el área de píxeles y atributos
 17+  8A72 CD 57 85         CALL COLOR_BORDE_PANTALLA   ; Restablece el borde (posiblemente a blanco, según la rutina)
 18+  8A75 C9               RET
 19+  8A76
 20+  8A76              ; --------------------------------------------------------------------------------------------
 21+  8A76              ; COMMON_HANDLE_PLAY_RESPONSE
 22+  8A76              ; Gestiona la navegación estándar después de una pregunta de "Jugar".
 23+  8A76              ; Esta rutina NO RETORNA. Transfiere el control (JP) a otra pantalla.
 24+  8A76              ;
 25+  8A76              ; ENTRADA:
 26+  8A76              ;   IX = Puntero al mensaje de título (para COMMON_SHOW_CONFIRM_SCREEN)
 27+  8A76              ;   IY = Puntero a la pregunta (para COMMON_SHOW_CONFIRM_SCREEN)
 28+  8A76              ; --------------------------------------------------------------------------------------------
 29+  8A76              COMMON_HANDLE_PLAY_RESPONSE:
 30+  8A76                  ; 1. Mostrar la pantalla de confirmación
 31+  8A76 CD 81 8A         CALL COMMON_SHOW_CONFIRM_SCREEN ; Espera una respuesta S/N
 32+  8A79                                                  ; Retorna A=1 (Sí) o A=0 (No)
 33+  8A79
 34+  8A79                  ; 2. Evaluar la respuesta
 35+  8A79 FE 01            CP 1                            ; Compara A con 1 (Sí)
 36+  8A7B
 37+  8A7B                  ; 3. Saltar a la pantalla correspondiente
 38+  8A7B CA 04 8B         JP Z, GAME_SCREEN               ; Si A=1 (Z=1), saltar a la pantalla de juego
 39+  8A7E C3 D5 8A         JP COMMON_MESSAGE_BYE_SCREEN    ; Si A=0 (Z=0), saltar a la pantalla de despedida
 40+  8A81
 41+  8A81              ; --------------------------------------------------------------------------------------------
 42+  8A81              ; COMMON_SHOW_CONFIRM_SCREEN
 43+  8A81              ; Muestra una interfaz estandarizada de pregunta S/N en la parte inferior
 44+  8A81              ; de la pantalla y espera la entrada del usuario.
 45+  8A81              ;
 46+  8A81              ; ENTRADA:
 47+  8A81              ;   IX = Dirección del mensaje de título (arriba). Si es 0, se omite.
 48+  8A81              ;   IY = Dirección de la pregunta (abajo, ej: "¿Quieres jugar?").
 49+  8A81              ;
 50+  8A81              ; SALIDA:
 51+  8A81              ;   A = 1 (si el usuario pulsó 'S')
 52+  8A81              ;   A = 0 (si el usuario pulsó 'N')
 53+  8A81              ; --------------------------------------------------------------------------------------------
 54+  8A81              COMMON_SHOW_CONFIRM_SCREEN:
 55+  8A81                  ; 1. Mostrar Título Superior (si existe)
 56+  8A81 DD 7E 00         LD A, (IX)                  ; Carga el primer byte del puntero IX
 57+  8A84 B7               OR A                        ; Comprueba si A es 0 (cadena vacía)
 58+  8A85 28 09            JR Z, .SKIP_TITLE           ; Si es 0, omitir el dibujo del título
 59+  8A87
 60+  8A87 3E 46            LD A, COLOR_AMARILLO_NEGRO  ; Atributo para el título
 61+  8A89 06 01            LD B, 1                     ; Fila 1
 62+  8A8B 0E 07            LD C, 7                     ; Columna 7
 63+  8A8D CD E8 86         CALL PRINTAT                ; (IX ya está cargado con el título)
 64+  8A90
 65+  8A90              .SKIP_TITLE:
 66+  8A90                  ; 2. Mostrar Pregunta Inferior (ej: "Quieres jugar?")
 67+  8A90 3E FA            LD A, COLOR_ROJO_BLANCO_FLASH ; Atributo parpadeante
 68+  8A92 06 14            LD B, 20                    ; Fila 20
 69+  8A94 0E 04            LD C, 4                     ; Columna 4
 70+  8A96 DD E5            PUSH IX                     ; Salvar IX (título) temporalmente
 71+  8A98 FD E5 DD E1      LD IX, IY                   ; Cargar IX con la pregunta (IY)
 72+  8A9C CD E8 86         CALL PRINTAT
 73+  8A9F DD E1            POP IX                      ; Restaurar IX
 74+  8AA1
 75+  8AA1                  ; 3. Mostrar prompt "(S / N):" al lado de la pregunta
 76+  8AA1 3E FA            LD A, COLOR_ROJO_BLANCO_FLASH ; Mismo atributo
 77+  8AA3 06 14            LD B, 20                      ; Misma fila 20
 78+  8AA5 0E 14            LD C, 20                      ; Columna 20 (más a la derecha)
 79+  8AA7 DD E5            PUSH IX
 80+  8AA9 DD 21 5E 80      LD IX, CONFIRMATION_MESSAGE_SN ; Puntero al texto "(S / N):"
 81+  8AAD CD E8 86         CALL PRINTAT
 82+  8AB0 DD E1            POP IX
 83+  8AB2
 84+  8AB2                  ; 4. Leer respuesta del usuario (Bloqueante)
 85+  8AB2 CD 65 85         CALL KEYBOARD_LEER_SN       ; Espera hasta que se pulse 'S' o 'N'
 86+  8AB5 32 01 81         LD (MESSAGE_KEY_SN), A      ; Guarda el carácter ('S' o 'N') en una variable
 87+  8AB8
 88+  8AB8                  ; 5. Mostrar la tecla pulsada (Eco visual)
 89+  8AB8 3E FA            LD A, COLOR_ROJO_BLANCO_FLASH ; Mismo atributo
 90+  8ABA 06 14            LD B, 20
 91+  8ABC 0E 1C            LD C, 28
 92+  8ABE DD E5            PUSH IX
 93+  8AC0 DD 21 01 81      LD IX, MESSAGE_KEY_SN       ; Puntero a la variable que contiene la tecla
 94+  8AC4 CD E8 86         CALL PRINTAT
 95+  8AC7 DD E1            POP IX
 96+  8AC9
 97+  8AC9                  ; 6. Evaluar y preparar el valor de retorno
 98+  8AC9 3A 01 81         LD A, (MESSAGE_KEY_SN)
 99+  8ACC FE 53            CP 'S'                      ; ¿Pulsó 'S'?
100+  8ACE 28 02            JR Z, .RETURN_YES
