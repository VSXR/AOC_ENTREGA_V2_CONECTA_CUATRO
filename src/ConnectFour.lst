388+  86D3
389+  86D3                  ; Si el juego continúa, retorna aquí
390+  86D3 CD 51 81         CALL DIBUJAR_FICHA_JUGADOR          ; Preview del siguiente jugador
391+  86D6 3A 04 81         LD A, (CURRENT_ROW)
392+  86D9 32 05 81         LD (PREVIOUS_ROW), A                ; Sincronizar
393+  86DC C3 3D 86         JP .LOOP
394+  86DF
395+  86DF              .HANDLE_F_PRESS:
