 32+  86F7 32 6B 87     PREP_PRT:	LD (PRINT_ATTR),A			; Set Attribute
 33+  86FA CD 00 87     PREP_PRT_2:	CALL CRtoSCREEN
 34+  86FD C3 12 87     			JP CRtoATTR
