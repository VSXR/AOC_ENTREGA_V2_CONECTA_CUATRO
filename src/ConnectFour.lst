 84+  84BA E5               PUSH HL              ; Guardar H,L (celda actual)
 85+  84BB F5               PUSH AF              ; Guardar Color (A)
 86+  84BC
 87+  84BC                  ; 1. Borrar píxeles (poner a 0)
 88+  84BC CD 24 84         CALL POSXY_CalcPixelAddr_4000 ; HL = Dirección de píxel
 89+  84BF 06 08            LD B, 8              ; 8 líneas de píxeles por carácter
 90+  84C1 AF               XOR A                ; A = 0
 91+  84C2              .Pixel_Loop:
 92+  84C2 77               LD (HL), A           ; Escribir 0 en memoria de vídeo
 93+  84C3 24               INC H                ; Siguiente línea de píxel
 94+  84C4 10 FC            DJNZ .Pixel_Loop
 95+  84C6
 96+  84C6                  ; 2. Pintar atributo
 97+  84C6 F1               POP AF               ; Recuperar Color (A)
 98+  84C7 E1               POP HL               ; Recuperar H,L (coordenadas)
 99+  84C8 E5               PUSH HL              ; Guardar H,L otra vez (POSXY lo modifica)
100+  84C9
101+  84C9 CD 5B 84         CALL POSXY_CalcAttrAddr_5800 ; HL = Dirección de atributo
102+  84CC 77               LD (HL), A           ; Escribir el color
103+  84CD
104+  84CD E1               POP HL               ; Recuperar H,L
105+  84CE 2C               INC L                ; Siguiente columna (X+1)
106+  84CF 1D               DEC E                ; Decrementar contador de columnas
107+  84D0 20 E8            JR NZ, TABLERO_RellenarRect_ColLoop
108+  84D2
109+  84D2 E1               POP HL               ; Recuperar H,L (inicio de fila)
110+  84D3 24               INC H                ; Siguiente fila (Y+1)
111+  84D4 15               DEC D                ; Decrementar contador de filas
112+  84D5 20 E1            JR NZ, TABLERO_RellenarRect_RowLoop
