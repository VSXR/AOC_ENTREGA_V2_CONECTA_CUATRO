  7+  850E              ; FUNCIÓN: UTIL_PintarNfichasAlternandoColores
  8+  850E              ; Pinta N fichas consecutivas CON ESPACIO, alternando entre roja y amarilla.
  9+  850E              ;
 10+  850E              ; ENTRADAS:
 11+  850E              ;   H = Fila inicial (Y)
 12+  850E              ;   L = Columna inicial (X)
 13+  850E              ;   B = Número de fichas a pintar
 14+  850E              ; ==========================================================================
 15+  850E              UTIL_PintarNfichasAlternandoColores:
 16+  850E E5               PUSH HL
 16+  850F C5             PUSH BC
 16+  8510 D5             PUSH DE
 16+  8511 F5             PUSH AF  ; Preservar todos los registros
 17+  8512
 18+  8512                  ; --- Cargar colores desde memoria ---
 19+  8512 3A 0B 80         LD A, (COLOR_CUADRADO_ROJO)
 20+  8515 57               LD D, A                            ; Guarda color rojo en D
 21+  8516 3A 0A 80         LD A, (COLOR_CUADRADO_AMARILLO)
 22+  8519 5F               LD E, A                            ; Guarda color amarillo en E
 23+  851A 7B               LD A, E                            ; Empezar con el color Amarillo (E)
 24+  851B
 25+  851B              UTIL_PintarNfichasAlternandoColores_Loop:
 26+  851B                  ; Pinta la ficha de 16x16 con el color actual en A
 27+  851B CD 2A 83         CALL FICHAS_PintarFicha16
 28+  851E
 29+  851E                  ; --- Alternar color ---
 30+  851E BA               CP D                                ; ¿El color actual (A) es Rojo (D)?
 31+  851F 28 03            JR Z, .SET_YELLOW                   ; Si sí, saltar para poner Amarillo
 32+  8521 7A               LD A, D                             ; Si no, poner Rojo
 33+  8522 18 01            JR .COLOR_LISTO
 34+  8524
 35+  8524              .SET_YELLOW:
 36+  8524 7B               LD A, E                             ; Poner Amarillo
 37+  8525
 38+  8525              .COLOR_LISTO:
 39+  8525                  ; Avanza 3 posiciones (L+3).
 40+  8525                  ; (La ficha mide 2 (L, L+1). L+2 sería pegado. L+3 deja un carácter de espacio).
 41+  8525 2C               INC L
 41+  8526 2C             INC L
 41+  8527 2C             INC L
 42+  8528
