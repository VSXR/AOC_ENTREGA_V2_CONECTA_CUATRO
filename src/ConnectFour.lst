 52+  8441                  ; (H = Y normalizada 0-7, E = Base del tercio, L = X 0-31)
 53+  8441
 54+  8441 7C               LD A, H                               ; A = Y (0-7)
 55+  8442 CB 27            SLA A
 55+  8444 CB 27          SLA A
 55+  8446 CB 27          SLA A
 55+  8448 CB 27          SLA A
