 68+  845B              ; FUNCIÓN: POSXY_CalcAttrAddr_5800
 69+  845B              ;
 70+  845B              ; DESCRIPCIÓN:
 71+  845B              ;   Calcula la dirección de memoria de ATRIBUTOS (rango $5800 - $5AFF)
 72+  845B              ;   correspondiente a una coordenada de carácter (H=Y, L=X).
 73+  845B              ;
 74+  845B              ;   La fórmula es: Dirección = $5800 + (Y * 32) + X
 75+  845B              ;
 76+  845B              ; ENTRADA: H = Coordenada Y (0-23), L = Coordenada X (0-31)
 77+  845B              ; SALIDA:  HL = Dirección de atributo ($58xx - $5Axx)
 78+  845B              ; ====================================================================================================
 79+  845B              POSXY_CalcAttrAddr_5800:
 80+  845B F5               PUSH AF                              ; Preservar AF
 81+  845C
 82+  845C                  ; --- Cálculo del Byte Bajo (L) ---
 83+  845C 7C               LD A, H                              ; A = Y
 84+  845D CB 27            SLA A
 84+  845F CB 27          SLA A
 84+  8461 CB 27          SLA A
 84+  8463 CB 27          SLA A
 84+  8465 CB 27          SLA A    ; A = Y * 32 (5 desplazamientos)
 85+  8467 B5               OR L                                 ; A = (Y * 32) + X
 86+  8468 6F               LD L, A                              ; L = Byte bajo de la dirección
 87+  8469
 88+  8469                  ; --- Cálculo del Byte Alto (H) ---
 89+  8469 7C               LD A, H                              ; A = Y
 90+  846A CB 2F            SRA A
 90+  846C CB 2F          SRA A
 90+  846E CB 2F          SRA A                  ; A = Y / 8 (3 desplazamientos)
 91+  8470 F6 58            OR $58                               ; Combinar con la base de atributos $5800
 92+  8472 67               LD H, A                              ; H = Byte alto de la dirección
 93+  8473
 94+  8473 F1               POP AF                               ; Restaurar AF
 95+  8474 C9               RET
