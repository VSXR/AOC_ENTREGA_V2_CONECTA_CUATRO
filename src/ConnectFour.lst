  8+  82FE              ; FICHAS_PintarMatriz8x8
  9+  82FE              ; Dibuja una matriz de 8x8 píxeles (un carácter) en la pantalla.
 10+  82FE              ; Es la rutina gráfica de más bajo nivel.
 11+  82FE              ;
 12+  82FE              ; ENTRADA:
 13+  82FE              ;     HL -> Coordenadas (H = Y, L = X)
 14+  82FE              ;     A  -> Color del atributo (byte de color, ej: INK_ROJO + PAPER_AZUL)
 15+  82FE              ;     IX -> Dirección de la matriz de 8 bytes (patrón de píxeles)
 16+  82FE              ;
 17+  82FE              ; PROCESO:
 18+  82FE              ;     1. Calcula la dirección de atributos ($5800) y escribe el color (A).
 19+  82FE              ;     2. Calcula la dirección de píxeles ($4000) y la pone en HL.
 20+  82FE              ;     3. Entra en un bucle (B=8) que copia 8 bytes de (IX) a (HL),
 21+  82FE              ;        incrementando H (fila de píxeles) e IX (fuente) en cada paso.
 22+  82FE              ; --------------------------------------------------------------------------------------------
 23+  82FE              FICHAS_PintarMatriz8x8:
 24+  82FE C5               PUSH BC
 24+  82FF D5             PUSH DE
 24+  8300 FD E5          PUSH IY              ; Preservar registros
 25+  8302 F5               PUSH AF                                ; Preservar AF (el color)
 26+  8303
 27+  8303 DD E5 FD E1      LD IY, IX                              ; Guardar IX (puntero a matriz) en IY
 28+  8307 54 5D            LD DE, HL                              ; Guardar coordenadas (H,L) en DE
 29+  8309
 30+  8309                  ; 1. PINTAR ATRIBUTO DE COLOR
 31+  8309 CD 5B 84         CALL POSXY_CalcAttrAddr_5800           ; HL = dirección de atributo
 32+  830C 77               LD (HL), A                             ; Escribir el color en $58xx
 33+  830D
 34+  830D                  ; 2. CALCULAR POSICIÓN DE PÍXELES
 35+  830D 62 6B            LD HL, DE                              ; Restaurar coordenadas (H,L)
 36+  830F CD 24 84         CALL POSXY_CalcPixelAddr_4000          ; HL = dirección de píxel en $4xxx
 37+  8312
 38+  8312 06 08            LD B, 8                                ; Contador de 8 filas
 39+  8314
 40+  8314              ; 3. BUCLE DE DIBUJO (Copia 8 bytes de IX a HL)
 41+  8314              FICHAS_PaintMatrix8x8_Loop:
 42+  8314 DD 4E 00         LD C, (IX)                             ; C = byte del patrón de píxeles
 43+  8317 71               LD (HL), C                             ; Escribir el byte en la memoria de vídeo
 44+  8318
 45+  8318 DD 23            INC IX                                 ; Siguiente byte del patrón
 46+  831A 24               INC H                                  ; Siguiente fila de píxeles en pantalla
 47+  831B 05               DEC B
 48+  831C 20 F6            JR NZ, FICHAS_PaintMatrix8x8_Loop      ; Repetir 8 veces
 49+  831E
 50+  831E                  ; 4. RESTAURACIÓN
 51+  831E 62 6B            LD HL, DE                              ; Restaurar coordenadas originales
 52+  8320 FD E5 DD E1      LD IX, IY                              ; Restaurar puntero a matriz original
 53+  8324
 54+  8324 F1               POP AF                                 ; Restaurar AF (color)
 55+  8325 FD E1            POP IY
 55+  8327 D1             POP DE
 55+  8328 C1             POP BC
 56+  8329 C9               RET
