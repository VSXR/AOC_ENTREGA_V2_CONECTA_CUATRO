 37+  8700              ;-----------------------------------------------------------------------------------------
 38+  8700              ; CRtoSCREEN - Converts a scr char coord into a SCREEN Address   b,c = y,x positions
 39+  8700              ;	IN  - B=Row, C=Column
 40+  8700              ;	OUT - HL=Address in screen also stored in (SCR_CUR_PTR)
 41+  8700              ;	Conversion:
 42+  8700              ;			Row FFfff   Column CCCCC
 43+  8700              ;			HL=%010FF000 fffCCCCC
 44+  8700              ;-----------------------------------------------------------------------------------------
 45+  8700              CRtoSCREEN:
 46+  8700 78           			LD A,B						; %___FFfff
 47+  8701 F6 40        			OR #40						; %010FFfff
 48+  8703 E6 F8        			AND #F8						; %010FF000
 49+  8705 67           			LD H,A
 50+  8706
 51+  8706 78           			LD A,B						; %___FFfff
 52+  8707 E6 07        			AND #7						; %00000fff
 53+  8709 0F           			RRCA						; %f00000ff
 54+  870A 0F           			RRCA						; %ff00000f
 55+  870B 0F           			RRCA						; %fff00000
 56+  870C B1           			OR C						; %fffCCCCC
 57+  870D 6F           			LD L,A
 58+  870E 22 67 87                 LD (SCR_CUR_PTR),HL			; Update Variable
 59+  8711 C9                       RET
